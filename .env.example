# App Identity
APP_IDENTIFIER=com.company.app
SCHEME=App

# Apple Developer
APPLE_ID=your@email.com
TEAM_ID=XXXXXXXXXX
ITC_TEAM_ID=XXXXXXXXXX

# Match (Code Signing)
MATCH_GIT_URL=https://github.com/your-org/certificates.git
MATCH_PASSWORD=your-match-encryption-password

# Notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/XXX/XXX

# CI (set automatically in most CI environments)
# CI=true
