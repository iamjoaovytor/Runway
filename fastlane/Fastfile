# Runway — Production-ready Fastlane template
# https://github.com/iamjoaovytor/Runway

default_platform(:ios)

import "lanes/certificates.rb"
import "lanes/screenshots.rb"
import "lanes/build.rb"
import "lanes/deploy.rb"
import "lanes/monitoring.rb"
import "lanes/ci.rb"

platform :ios do
  before_all do
    setup_ci if ENV["CI"]
  end

  after_all do |lane|
    clean_build_artifacts
  end

  error do |lane, exception|
    if ENV["SLACK_WEBHOOK_URL"]
      slack(
        message: "Lane `#{lane}` failed",
        payload: { "Error" => exception.message },
        success: false
      )
    end
  end
end
